# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_private_chat_id_here

# IVAS cookies (export from browser DevTools → Application → Cookies)
# Copy the values of these two cookies from ivasms.com after logging in manually:
IVAS_XSRF_TOKEN=your_xsrf_token_here
IVAS_SESSION=your_ivas_sms_session_here

# How often to poll (seconds). Cookies expire ~2h so keep this low.
POLL_INTERVAL=60
